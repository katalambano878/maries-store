# =============================================================================
# .env.local.example
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (REQUIRED)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_DB_PASSWORD=your_supabase_db_password_here

# -----------------------------------------------------------------------------
# App URL (REQUIRED in production — payment callbacks/return URLs)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# -----------------------------------------------------------------------------
# Payments - Hubtel (PRIMARY gateway)
# From the Hubtel dashboard. Merchant account number = Hubtel Collection
# Account (POS Sales) number for THIS store — do NOT reuse another store's credentials.
# -----------------------------------------------------------------------------
HUBTEL_API_ID=your_hubtel_api_id_here
HUBTEL_API_KEY=your_hubtel_api_key_here
HUBTEL_MERCHANT_ACCOUNT_NUMBER=your_hubtel_collection_account_number_here

# -----------------------------------------------------------------------------
# Moolre SMS (REQUIRED for SMS notifications — not used for payments)
# -----------------------------------------------------------------------------
MOOLRE_SMS_API_KEY=your_moolre_sms_api_key_here
# MOOLRE_SMS_SENDER_ID=MariesHair

# Comma-separated list of admin phone numbers to receive order SMS alerts
# Defaults to a hardcoded number if not set — set this explicitly in production
ADMIN_SMS_NUMBERS=0540729570

# -----------------------------------------------------------------------------
# Paystack Payments (legacy / alternate card option)
# -----------------------------------------------------------------------------
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here

# -----------------------------------------------------------------------------
# Email — Resend (REQUIRED for order confirmation emails)
# -----------------------------------------------------------------------------
RESEND_API_KEY=your_resend_api_key_here
ADMIN_EMAIL=your_admin_email_here
EMAIL_FROM=Your Store Name <no-reply@yourdomain.com>

# -----------------------------------------------------------------------------
# Cron Jobs (REQUIRED if using Vercel Cron or any cron runner)
# Without this set, the /api/cron/payment-reminders endpoint is blocked entirely.
# -----------------------------------------------------------------------------
CRON_SECRET=your_random_cron_secret_here

# -----------------------------------------------------------------------------
# Google reCAPTCHA v3 (REQUIRED for spam protection on public forms)
# Without these set, reCAPTCHA verification will BLOCK requests (fail-closed).
# -----------------------------------------------------------------------------
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# -----------------------------------------------------------------------------
# Google Analytics (optional)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# -----------------------------------------------------------------------------
# Google Search Console (optional)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_google_verification_token_here
